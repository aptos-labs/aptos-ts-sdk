{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "//#build"],
      "outputs": ["dist/**"]
    },
    "//#build": {
      "inputs": ["src/**", "tsup.config.ts", "tsconfig.json", "package.json"],
      "outputs": ["dist/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "//#test": {
      "inputs": ["src/**", "tests/**", "vitest.config.ts", "tsconfig.json", "package.json"],
      "dependsOn": ["//#build"]
    },
    "lint": {},
    "//#lint": {
      "inputs": ["src/**", "tests/**", "biome.json"]
    },
    "check": {},
    "//#check": {
      "inputs": ["src/**", "tests/**", "biome.json"]
    },
    "fmt": {
      "cache": false
    },
    "//#fmt": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}

