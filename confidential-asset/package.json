{
  "name": "@aptos-labs/confidential-asset",
  "description": "Aptos Confidential Assets SDK",
  "packageManager": "pnpm@10.30.3",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "bugs": {
    "url": "https://github.com/aptos-labs/aptos-ts-sdk/issues/new/choose"
  },
  "homepage": "https://aptos-labs.github.io/aptos-ts-sdk/",
  "version": "1.1.1",
  "sideEffects": false,
  "main": "dist/common/index.js",
  "module": "dist/esm/index.mjs",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "require": {
        "types": "./dist/common/index.d.ts",
        "default": "./dist/common/index.js"
      },
      "import": {
        "types": "./dist/esm/index.d.mts",
        "default": "./dist/esm/index.mjs"
      }
    },
    "./dist/common/cli/index.js": "./dist/common/cli/index.js",
    "./dist/esm/cli/index.mjs": "./dist/esm/cli/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build:clean": "rm -rf dist",
    "build": "pnpm build:clean && tsc -p tsconfig.build.json",
    "build:types": "tsc -p tsconfig.build.json --outDir ./dist/types --declaration --emitDeclarationOnly",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.mts",
    "e2e-test": "vitest run tests/e2e",
    "indexer-codegen": "graphql-codegen --config ./src/indexer/codegen.yaml",
    "publish-zeta": "pnpm build && npm publish --tag zeta"
  },
  "peerDependencies": {
    "@aptos-labs/ts-sdk": "^5.2.1 || ^6.3.1 || ^7.0.0"
  },
  "dependencies": {
    "@aptos-labs/confidential-asset-bindings": "^1.1.1",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@aptos-labs/ts-sdk": "^6.3.1",
    "@swc/cli": "^0.8.0",
    "@swc/core": "^1.15.18",
    "@types/node": "^22.19.13",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "playwright": "^1.59.1",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "vite": "^7.3.2"
  },
  "pnpm": {
    "overrides": {
      "@aptos-labs/aptos-client": "^4.0.0",
      "glob@^10": "^10.5.0",
      "minimatch@^9": "^9.0.7",
      "file-type": "21.3.3",
      "yauzl": "3.2.1",
      "postcss": "^8.5.10",
      "uuid": "^14.0.0",
      "@xmldom/xmldom": "^0.8.13",
      "picomatch@^2": "^2.3.2",
      "picomatch@^4": "^4.0.4",
      "brace-expansion@^2": "^2.0.3"
    }
  }
}
