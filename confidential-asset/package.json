{
  "name": "@aptos-labs/confidential-asset",
  "description": "Aptos Confidential Assets SDK",
  "packageManager": "pnpm@10.30.3",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "bugs": {
    "url": "https://github.com/aptos-labs/aptos-ts-sdk/issues/new/choose"
  },
  "homepage": "https://aptos-labs.github.io/aptos-ts-sdk/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aptos-labs/aptos-ts-sdk.git",
    "directory": "confidential-asset"
  },
  "version": "1.1.1",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build:clean": "rm -rf dist",
    "build": "pnpm build:clean && tsc -p tsconfig.build.json",
    "prepublishOnly": "pnpm run build",
    "_fmt": "biome format",
    "fmt": "biome format --write",
    "format": "pnpm fmt",
    "lint": "biome lint",
    "check": "biome check",
    "test": "vitest run",
    "test:browser": "vitest run --config vitest.browser.config.mts",
    "e2e-test": "vitest run tests/e2e",
    "indexer-codegen": "graphql-codegen --config ./src/indexer/codegen.yaml",
    "publish-zeta": "pnpm build && npm publish --tag zeta"
  },
  "peerDependencies": {
    "@aptos-labs/ts-sdk": "^5.2.1 || ^6.3.1 || ^7.0.0"
  },
  "dependencies": {
    "@aptos-labs/confidential-asset-bindings": "^1.1.1",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0"
  },
  "devDependencies": {
    "@aptos-labs/ts-sdk": "^6.3.1",
    "@biomejs/biome": "2.4.6",
    "@types/node": "^22.19.13",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "playwright": "^1.59.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5",
    "vite": "^7.3.2"
  },
  "pnpm": {
    "overrides": {
      "@aptos-labs/aptos-client": "^4.0.0",
      "glob@^10": "^10.5.0",
      "minimatch@^9": "^9.0.7",
      "file-type": "21.3.3",
      "yauzl": "3.2.1",
      "postcss": "^8.5.10",
      "uuid": "^14.0.0",
      "@xmldom/xmldom": "^0.8.13",
      "picomatch@^2": "^2.3.2",
      "picomatch@^4": "^4.0.4",
      "brace-expansion@^2": "^2.0.3"
    }
  }
}
